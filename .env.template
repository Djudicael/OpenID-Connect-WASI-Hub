# OpenID Connect WASI Hub — local dev / E2E environment template
#
# Copy this file to `.env` for local use.
# `crates/oidc-dev` loads `.env` automatically via dotenv.
#
# Notes:
# - `DEFAULT_EMAIL` / `DEFAULT_PASSWORD` are used by:
#   - `cargo run -p oidc-dev -- start`
#   - `cargo run -p oidc-dev -- e2e ...`
#   - Playwright E2E helpers when the values are injected by `oidc-dev`
# - `PLAYWRIGHT_BASE_URL` is mainly for direct Playwright runs.
#   When you run `cargo run -p oidc-dev -- e2e`, it is injected automatically
#   from the running dev proxy and does not need to be hardcoded here.

DEFAULT_EMAIL=
DEFAULT_PASSWORD=

# Optional default for direct/manual Playwright usage.
# Override this when targeting a manually started `oidc-wasm-dev` proxy.
PLAYWRIGHT_BASE_URL=http://localhost:3000
